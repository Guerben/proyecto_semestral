# ============================================================================
# .env - Variables de Entorno para Docker Compose
# ============================================================================
# Copiar este archivo a .env y modificar los valores según sea necesario
# Este archivo NO debe versionarse en Git (agregar a .gitignore)
#
# Instrucciones:
# 1. Copiar: cp .env.example .env
# 2. Editar los valores con tus credenciales
# 3. Los valores por defecto están comentados con #
# ============================================================================

# ============================================================================
# BASE DE DATOS - MySQL
# ============================================================================
# Contraseña del usuario root (cambiar en producción)
DB_ROOT_PASSWORD=admin123

# Nombre de la base de datos a crear
DB_NAME=proyecto_db

# Usuario de la aplicación (no-root)
DB_USER=appuser

# Contraseña del usuario de la aplicación
DB_PASSWORD=appuser123

# Puerto expuesto de MySQL (localhost:puerto)
DB_PORT=3306

# ============================================================================
# BACKEND - Spring Boot APIs
# ============================================================================
# Puerto para API de Ventas
VENTAS_PORT=8080

# Puerto para API de Despachos
DESPACHOS_PORT=8081

# Perfil de Spring (development, production, test)
SPRING_PROFILES_ACTIVE=development

# ============================================================================
# FRONTEND - React
# ============================================================================
# Puerto para acceder al Frontend
FRONTEND_PORT=3000

# URL de la API de Ventas (vista desde el cliente)
VITE_API_VENTAS_URL=http://localhost:8080

# URL de la API de Despachos (vista desde el cliente)
VITE_API_DESPACHOS_URL=http://localhost:8081

# ============================================================================
# BUILD - Información de compilación
# ============================================================================
# Fecha de compilación (formato ISO 8601)
BUILD_DATE=2024-01-01T00:00:00Z

# ============================================================================
# PRODUCCIÓN / EC2 (docker-compose.prod.yml en el servidor)
# ============================================================================
# En la EC2, copia este archivo a /opt/isy1101/.env y ajusta valores reales.
# Namespace debe coincidir con GitHub Variable DOCKER_HUB_NAMESPACE y con Docker Hub.

DOCKER_REGISTRY=docker.io
DOCKER_HUB_NAMESPACE=tu-usuario
IMAGE_TAG=latest

# Puerto en el HOST donde se publica Nginx (80 típico en producción; requiere SG abierto)
FRONTEND_PORT=80

# Perfil Spring en contenedores (production recomendado en EC2)
SPRING_PROFILES_ACTIVE=production

# Opcional: forzar validate en prod solo si ya migraste el esquema con Flyway/Liquibase
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# -----------------------------------------------------------------------------
# Registro genérico (alternativa a Docker Hub)
# -----------------------------------------------------------------------------
# DOCKER_REGISTRY=your-registry.azurecr.io
# DOCKER_USERNAME=your-username
# DOCKER_PASSWORD=your-password
